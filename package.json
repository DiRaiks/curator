{
  "name": "vault-workflow-ide",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop workflow IDE for Markdown vaults",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop",
    "build": "npm run build -w apps/desktop && npm run open:dmg",
    "open:dmg": "ls -t target/release/bundle/dmg/*.dmg 2>/dev/null | head -1 | xargs -I{} open {}",
    "tauri": "npm run tauri -w apps/desktop",
    "tauri:dev": "npm run tauri -w apps/desktop -- dev",
    "tauri:build": "npm run tauri -w apps/desktop -- build",
    "typecheck": "npm run typecheck -w apps/desktop"
  }
}
