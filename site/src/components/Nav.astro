---
import { Icon } from "astro-icon/components";
import BrandMark from "./BrandMark.astro";
import { SITE, NAV, withBase } from "../consts";
---

<header
  class="sticky top-0 z-50 border-b border-zinc-800/70 bg-zinc-950/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8"
  >
    <a
      href={withBase("/")}
      class="press flex items-center gap-2.5 text-zinc-100"
      aria-label={`${SITE.name} home`}
    >
      <BrandMark class="h-6 w-6 text-accent-500" />
      <span class="text-[15px] font-semibold tracking-tight">{SITE.name}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 md:flex">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class="rounded-lg px-3 py-2 text-sm text-zinc-400 transition-colors duration-200 hover:text-zinc-100"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        href={SITE.repo}
        target="_blank"
        rel="noreferrer"
        class="press inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-900 px-3.5 py-2 text-sm font-medium text-zinc-100 transition-colors duration-200 hover:border-zinc-600 hover:bg-zinc-800"
      >
        <Icon name="ph:github-logo" class="h-4 w-4" />
        <span>GitHub</span>
      </a>
    </div>
  </nav>
</header>
